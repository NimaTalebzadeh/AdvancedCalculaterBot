using System;
using System.Numerics;
using AdvancedCalculaterBot.Services.Equations;

namespace TestApp
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("Testing Transcendental and Quintic Equation Solvers");
            Console.WriteLine("====================================================");

            // Test cases from the design
            string[] testEquations = {
                "x^5 - 3x^3 + 2x - 1 = 0",           // Quintic
                "sin(x) = 0.5",                      // Trigonometric (should give x = 30)
                "x^2 + sin(x) = 1",                  // Mixed polynomial/trigonometric
                "x^4 - 10x^2 + 9 = 0",               // Quartic (should use existing solver)
                "x^5 - 1 = 0",                       // Quintic roots of unity
                "log(x) + x = 3",                    // Logarithmic equation
                "exp(x) = 5"                         // Exponential equation
            };

            foreach (string equation in testEquations)
            {
                Console.WriteLine($"Input: {equation}");
                try
                {
                    string result = EquationSolverService.Solve(equation);
                    Console.WriteLine($"Output: {result}");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error: {ex.Message}");
                }
                Console.WriteLine();
            }
        }
    }
}